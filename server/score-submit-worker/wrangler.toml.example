name = "attack-of-the-dragon-score-submit"
main = "worker.js"
compatibility_date = "2026-07-01"

[[d1_databases]]
binding = "DB"
database_name = "attack-of-the-dragon-scores"
database_id = "replace-with-d1-database-id"
migrations_dir = "migrations"

[vars]
ALLOWED_ORIGIN = "https://your-cloudflare-pages-or-custom-domain.example"
GOOGLE_CLIENT_IDS = "your-google-oauth-client-id.apps.googleusercontent.com"
APPLE_CLIENT_IDS = "io.github.iogami0103.attackofthedragon"
